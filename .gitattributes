# Auto detect text files and perform LF normalization
* text=auto

# Dart source files
*.dart text eol=lf

# Common text files
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.swift text eol=lf
*.h text eol=lf
*.cc text eol=lf
*.cmake text eol=lf
*.sh text eol=lf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
